# ============================================
# Armenia Tours - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Database - Supabase PostgreSQL Connection String
# Get this from: Supabase Dashboard → Settings → Database → Connection string
# For Vercel deployment, use the Pooler connection (port 6543):
#   postgresql://postgres.ogvdaiixebxivyfbyhqb:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# For local development / prisma db push, use Direct connection (port 5432):
#   postgresql://postgres:[PASSWORD]@db.ogvdaiixebxivyfbyhqb.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.ogvdaiixebxivyfbyhqb.supabase.co:5432/postgres

# Supabase Client
NEXT_PUBLIC_SUPABASE_URL=https://ogvdaiixebxivyfbyhqb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# SMTP Email (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=thebeautyofarmenia@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-key
